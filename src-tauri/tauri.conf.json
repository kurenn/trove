{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trove",
  "version": "2.0.0",
  "identifier": "io.spoolr.trove",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Trove",
        "width": 1280,
        "height": 860,
        "minWidth": 720,
        "minHeight": 560
      },
      {
        "label": "launcher",
        "title": "Trove Quick Find",
        "width": 1280,
        "height": 820,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$APPCACHE/**", "$APPDATA/**", "/Volumes/**", "/mnt/**", "/media/**", "/srv/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
